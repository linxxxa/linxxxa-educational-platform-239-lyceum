# Скопируйте в .env и при необходимости поправьте.
# Бэкенд подхватывает .env из этой папки при старте (python-dotenv).

# Базовый URL фронтенда — ссылки в письмах и приглашениях
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Почта «поделиться колодой»
# ---------------------------------------------------------------------------
# Вариант A — без реальной отправки (письмо в лог терминала uvicorn):
SMTP_HOST=console
SMTP_FROM=EduLab <noreply@localhost>

# Вариант B — Gmail (обычный пароль от аккаунта НЕ подойдёт — только пароль приложения):
# 1) Включите двухэтапную проверку: https://myaccount.google.com/security
# 2) Создайте пароль приложения «Почта» / «Другое»: https://myaccount.google.com/apppasswords
# 3) Закомментируйте блок «console» выше и раскомментируйте строки ниже, подставьте свой Gmail и 16-символьный пароль приложения.
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=vash@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_FROM=EduLab <vash@gmail.com>
# SMTP_USE_TLS=true

# База (если не задано — SQLite ./platform_database.db)
# DATABASE_URL=postgresql://user:pass@localhost:5432/edulab
